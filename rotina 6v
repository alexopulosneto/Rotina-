// ── TEMPO ──
const ratings={};

window.togB=function(id){
  const chip=$('chip-'+id),panel=$('panel-'+id);
  const on=!chip.classList.contains('on');
  chip.classList.toggle('on',on);
  panel.classList.toggle('off',!on);
  calcHoras();
};

window.rate=function(id,val){
  ratings[id]=val;
  const row=$('r-'+id);if(!row)return;
  row.querySelectorAll('.ropt').forEach(r=>r.classList.remove('sel-ruim','sel-medio','sel-bom'));
  const i={ruim:0,medio:1,bom:2}[val];
  row.querySelectorAll('.ropt')[i]?.classList.add('sel-'+val);
};

function toMin(t){if(!t)return null;const[h,m]=t.split(':').map(Number);return h*60+m;}
function durStr(a,b){if(!a||!b)return null;let d=toMin(b)-toMin(a);if(d<=0)return null;const h=Math.floor(d/60),m=d%60;return h>0?`${h}h${m>0?m+'min':''}`:`${m}min`;}

window.calcHoras=function(){
  let obrig=0;
  const add=(a,b)=>{if(!a||!b)return;let d=toMin(b)-toMin(a);if(d>0)obrig+=d;};
  if($('chip-t1').classList.contains('on'))add($('t1-ini').value,$('t1-fim').value);
  if($('chip-alm').classList.contains('on'))add($('alm-ini').value,$('alm-fim').value);
  if($('chip-t2').classList.contains('on'))add($('t2-ini').value,$('t2-fim').value);
  if($('chip-gym').classList.contains('on'))add($('gym-ini').value,$('gym-fim').value);
  const total=17*60,livres=Math.max(0,total-obrig);
  const hL=Math.floor(livres/60),mL=livres%60,pct=Math.round(livres/total*100);
  $('horas-livres').textContent=hL>0?`${hL}h${mL>0?mL+'m':''}`:`${mL}m`;
  $('horas-sub').textContent=obrig>0?`${Math.floor(obrig/60)}h em obrigações`:'Preencha a rotina';
  $('horas-bar').style.width=pct+'%';
};

function montarDia(){
  const d={};
  if($('chip-t1').classList.contains('on'))d.trabManha={ini:$('t1-ini').value,fim:$('t1-fim').value,dur:durStr($('t1-ini').value,$('t1-fim').value),rating:ratings.t1};
  if($('chip-alm').classList.contains('on'))d.almoco={ini:$('alm-ini').value,fim:$('alm-fim').value};
  if($('chip-t2').classList.contains('on'))d.trabTarde={ini:$('t2-ini').value,fim:$('t2-fim').value,dur:durStr($('t2-ini').value,$('t2-fim').value),rating:ratings.t2};
  if($('chip-gym').classList.contains('on'))d.academia={ini:$('gym-ini').value,fim:$('gym-fim').value,dur:durStr($('gym-ini').value,$('gym-fim').value),treino:$('gym-treino').value,rating:ratings.gym};
  return d;
}

// ── RECOMENDAÇÃO POR REGRAS (sem IA) ──
window.analisarDia=function(){
  const dia=montarDia();
  const btn=$('btn-tempo');btn.disabled=true;

  // Salva dia
  const key=today();
  const hist=state.hist||[];
  const filtered=hist.filter(x=>x.date!==key);
  filtered.unshift({date:key,...dia,ts:Date.now()});
  state.hist=filtered.slice(0,30);
  fbSaveD('hist',state.hist);

  // Calcular carga
  const temTrab=dia.trabManha||dia.trabTarde;
  const temGym=!!dia.academia;
  const trabRuim=dia.trabManha?.rating==='ruim'||dia.trabTarde?.rating==='ruim';
  const gymRuim=dia.academia?.rating==='ruim';
  const trabBom=dia.trabManha?.rating==='bom'&&(!dia.trabTarde||dia.trabTarde?.rating==='bom');

  let carga,cargaLabel;
  if(temTrab&&temGym&&(trabRuim||gymRuim)){carga='pesado';cargaLabel='Dia pesado 💀';}
  else if(temTrab&&temGym){carga='moderado';cargaLabel='Dia completo 😤';}
  else if(temTrab&&!temGym){carga='medio';cargaLabel='Só trabalho hoje';}
  else if(!temTrab&&temGym){carga='folga-gym';cargaLabel='Folga + academia';}
  else{carga='leve';cargaLabel='Dia leve 🙂';}

  // Histórico — o que foi recomendado nos últimos dias
  const semana={};
  state.hist.slice(1,8).forEach(d=>(d.rec||[]).forEach(a=>{semana[a]=(semana[a]||0)+1;}));
  const diasSemFacul=(semana.faculdade||0)+(semana.prf||0);
  const diasSemProg=semana.programacao||0;
  const diasSemSP=semana.socialpro||0;
  const diasSemDesc=semana.descanso||0;

  // Pool de atividades por carga
  const pools={
    pesado:[
      {titulo:'😴 Descanse de verdade',desc:'Você trabalhou e treinou. Hoje o descanso É produtivo. Assiste algo, deita, não força.',tag:'descanso'},
      {titulo:'📱 SocialPro no automático',desc:'Só assiste os vídeos passivamente. Sem pressão de fazer nada.',tag:'socialpro'},
    ],
    moderado:[
      {titulo:'📱 SocialPro',desc:'Bom momento pra ver uns vídeos do curso enquanto relaxa.',tag:'socialpro'},
      {titulo:'📖 Leitura leve',desc:'30 minutinhos de leitura antes de dormir.',tag:'leitura'},
      {titulo:'🎓 Faculdade (30min)',desc:'Só uma atividade ou uma aula. Sem pressão.',tag:'faculdade'},
      {titulo:'🚔 PRF (30min)',desc:'Um bloco curto de estudo. Vale mais do que zero.',tag:'prf'},
    ],
    medio:[
      {titulo:'🎓 Faculdade',desc:'Você tem tempo e energia. Uma hora de faculdade vale muito.',tag:'faculdade'},
      {titulo:'🚔 PRF',desc:'Aproveita pra avançar no conteúdo do concurso.',tag:'prf'},
      {titulo:'💻 Programação',desc:'Momento bom pra trabalhar em algum projeto.',tag:'programacao'},
      {titulo:'📱 SocialPro',desc:'Ver e aplicar algum conteúdo do curso.',tag:'socialpro'},
    ],
    'folga-gym':[
      {titulo:'🎓 Faculdade',desc:'Dia de folga do trabalho — ótimo pra avançar nos estudos.',tag:'faculdade'},
      {titulo:'💻 Programação',desc:'Com a cabeça mais descansada, bom pra programar.',tag:'programacao'},
      {titulo:'🚔 PRF',desc:'Aproveita a folga pra estudar pro concurso.',tag:'prf'},
    ],
    leve:[
      {titulo:'🎓 Faculdade',desc:'Dia tranquilo, aproveita pra estudar direito.',tag:'faculdade'},
      {titulo:'💻 Programação',desc:'Boa oportunidade pra trabalhar em algum projeto.',tag:'programacao'},
      {titulo:'🚔 PRF',desc:'Avança no conteúdo da prova.',tag:'prf'},
      {titulo:'📱 SocialPro',desc:'Vê e aplica algum conteúdo do curso.',tag:'socialpro'},
    ],
  };

  let pool=pools[carga]||pools.moderado;

  // Filtrar: se fez algo 2x nos últimos 3 dias, deprioritiza
  const rec3={};
  state.hist.slice(1,4).flatMap(d=>d.rec||[]).forEach(a=>{rec3[a]=(rec3[a]||0)+1;});
  pool.sort((a,b)=>(rec3[a.tag]||0)-(rec3[b.tag]||0));

  // Prioriza o que faz mais tempo que não faz
  if(diasSemFacul===0&&carga!=='pesado')pool.unshift({titulo:'⚠️ Faculdade — faz tempo!',desc:`Faz ${7-diasSemFacul} dias sem estudar. Vale muito encaixar hoje.`,tag:'faculdade'});
  if(diasSemDesc===0&&carga==='pesado')pool.unshift({titulo:'😴 Você precisa descansar',desc:'Faz dias sem descanso de verdade. Hoje não é dia de forçar.',tag:'descanso'});

  // Pega 1-3 tarefas dependendo da carga
  const maxTasks=carga==='pesado'?1:carga==='moderado'?2:3;
  const seen=new Set();
  const tasks=[];
  for(const t of pool){if(!seen.has(t.tag)){seen.add(t.tag);tasks.push({...t,n:tasks.length+1});if(tasks.length>=maxTasks)break;}}

  // Salva o que foi recomendado
  const idx=state.hist.findIndex(x=>x.date===key);
  if(idx>=0)state.hist[idx].rec=tasks.map(t=>t.tag);
  fbSave('hist',state.hist);

  // Renderiza
  const rec=$('rec-tempo');rec.classList.add('show');
  $('rec-sub').textContent=cargaLabel;
  $('rec-tasks').innerHTML=tasks.map(t=>`
    <div class="task">
      <div class="task-n">${t.n}</div>
      <div class="task-body"><strong>${t.titulo}</strong><span>${t.desc}</span></div>
    </div>`).join('');

  rec.scrollIntoView({behavior:'smooth',block:'start'});
  notif('✅ Dia analisado!');
  btn.disabled=false;
};

function initTempo(){
  calcHoras();
  const hist=state.hist||[];if(!hist.length)return;
  const d=hist[0];if(d.date!==today())return;
  if(d.trabManha){togB('t1');if(d.trabManha.ini)$('t1-ini').value=d.trabManha.ini;if(d.trabManha.fim)$('t1-fim').value=d.trabManha.fim;if(d.trabManha.rating)rate('t1',d.trabManha.rating);}
  if(d.almoco){togB('alm');if(d.almoco.ini)$('alm-ini').value=d.almoco.ini;if(d.almoco.fim)$('alm-fim').value=d.almoco.fim;}
  if(d.trabTarde){togB('t2');if(d.trabTarde.ini)$('t2-ini').value=d.trabTarde.ini;if(d.trabTarde.fim)$('t2-fim').value=d.trabTarde.fim;if(d.trabTarde.rating)rate('t2',d.trabTarde.rating);}
  if(d.academia){togB('gym');if(d.academia.ini)$('gym-ini').value=d.academia.ini;if(d.academia.fim)$('gym-fim').value=d.academia.fim;if(d.academia.treino)$('gym-treino').value=d.academia.treino;if(d.academia.rating)rate('gym',d.academia.rating);}
  calcHoras();
}

// ── SALDO ──
function calcSaldoNum(){
  const f=state.fin;
  const av=(f.avulsas||[]).reduce((s,a)=>s+(parseFloat(a.val)||0),0);
  const entrada=(parseFloat(f.salario)||0)+(parseFloat(f.anterior)||0)+av;
  const fx=(f.fixos||[]).reduce((s,x)=>s+(parseFloat(x.val)||0),0);
  const gs=(f.gastos||[]).reduce((s,g)=>s+(parseFloat(g.val)||0),0);
  return entrada-fx-gs;
}

function calcSaldo(){
  const f=state.fin;
  const av=(f.avulsas||[]).reduce((s,a)=>s+(parseFloat(a.val)||0),0);
  const entrada=(parseFloat(f.salario)||0)+(parseFloat(f.anterior)||0)+av;
  const fx=(f.fixos||[]).reduce((s,x)=>s+(parseFloat(x.val)||0),0);
  const gs=(f.gastos||[]).reduce((s,g)=>s+(parseFloat(g.val)||0),0);
  const saldo=entrada-fx-gs;
  const pctC=entrada>0?Math.min(100,Math.round(fx/entrada*100)):0;
  const pctS=entrada>0?Math.max(0,Math.round(saldo/entrada*100)):0;

  $('saldo-disp').textContent=fmtM(saldo);
  $('saldo-disp').style.color=saldo>=0?'var(--a2)':'var(--danger)';
  $('saldo-disp-sub').textContent=`de ${fmtM(entrada)} de renda`;
  $('saldo-disp-bar').style.width=pctS+'%';
  $('saldo-disp-bar').style.background=saldo>=0?'var(--a2)':'var(--danger)';
  $('saldo-top').textContent=fmtM(saldo);
  $('saldo-top').style.color=saldo>=0?'var(--a2)':'var(--danger)';
  $('saldo-sub').textContent=pctC+'% comprometido';
  $('saldo-bar').style.width=Math.max(0,100-pctC)+'%';

  if(entrada>0&&fx>0){
    $('pizza-wrap').style.display='block';
    drawPizza(pctC,100-pctC);
    $('pizza-legend').innerHTML=`<div class="pleg"><div class="pleg-dot" style="background:var(--danger)"></div><span>Fixos: ${pctC}%</span></div><div class="pleg"><div class="pleg-dot" style="background:var(--ok)"></div><span>Livre: ${100-pctC}%</span></div>`;
  }
}

