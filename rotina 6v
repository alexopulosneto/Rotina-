// METAS
window.addMeta=function(){
  const nome=$('meta-nome').value.trim(),total=parseFloat($('meta-total').value)||0,guardado=parseFloat($('meta-guardado').value)||0;
  if(!nome||!total){notif('Preenche os campos!',true);return;}
  if(!state.fin.metas)state.fin.metas=[];
  state.fin.metas.push({id:Date.now(),nome,total,guardado});
