  if(state.fin.salario)$('fin-salario').value=state.fin.salario;
  if(state.fin.anterior)$('fin-anterior').value=state.fin.anterior;
  renderAvulsas();renderFixos();renderGastos();renderMetas();calcSaldo();
}

