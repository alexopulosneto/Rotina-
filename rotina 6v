  renderMetas();fbSave('fin',state.fin);notif('✅ Meta adicionada!');
};
const metaCores=['var(--a)','var(--a2)','var(--ok)','var(--warn)','#c080ff'];
function renderMetas(){
  const el=$('metas-lista'),mt=state.fin?.metas||[];
  if(!mt.length){el.innerHTML='<div class="empty" style="padding:6px 0;">Nenhuma meta ainda.</div>';return;}
  el.innerHTML=mt.map((m,i)=>{const pct=Math.min(100,Math.round(m.guardado/m.total*100));const cor=metaCores[i%metaCores.length];return`<div class="meta-item"><div class="meta-header"><div class="meta-nome">${m.nome}</div><div class="meta-vals">${fmtM(m.guardado)} / ${fmtM(m.total)} · ${pct}%</div></div><div class="meta-bar"><div class="meta-fill" style="width:${pct}%;background:${cor};"></div></div></div>`;}).join('');
}

function drawPizza(pctC,pctL){
  const c=$('pizza-canvas');if(!c)return;const ctx=c.getContext('2d');const cx=40,cy=40,r=36;
  ctx.clearRect(0,0,80,80);
  const toRad=p=>(-Math.PI/2)+(p/100)*2*Math.PI;
  ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,toRad(0),toRad(pctC));ctx.closePath();ctx.fillStyle='#f04444';ctx.fill();
  ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,toRad(pctC),toRad(100));ctx.closePath();ctx.fillStyle='#7fff6b';ctx.fill();
  ctx.beginPath();ctx.arc(cx,cy,22,0,2*Math.PI);ctx.fillStyle='#0f1218';ctx.fill();
  ctx.fillStyle='#fff';ctx.font='bold 11px monospace';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(pctC+'%',cx,cy);
}

